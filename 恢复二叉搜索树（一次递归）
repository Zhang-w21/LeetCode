struct TreeNode *first = NULL, *second = NULL, *prev = NULL;

void inorder(struct TreeNode* root) {
    if (!root) return;
    inorder(root->left);
    if (prev && root->val < prev->val) {
        if (!first) first = prev;
        second = root;
    }
    prev = root;
    inorder(root->right);
}

void recoverTree(struct TreeNode* root) {
    first = NULL;
    second = NULL;
    prev = NULL;
    inorder(root);
    if (first && second) {
        int temp = first->val;
        first->val = second->val;
        second->val = temp;
    }
}
